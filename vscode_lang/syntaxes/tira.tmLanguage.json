{
  "scopeName": "source.tira",
  "name": "Tira",

  "patterns": [
  { "include": "#comments" },
  { "include": "#strings" },

  { "include": "#keywords" },
  { "include": "#numbers" },
  { "include": "#ranges" },
  { "include": "#operators" },

  { "include": "#kernel-functions" },
  { "include": "#functions" },
  { "include": "#class-identifiers" },

  { "include": "#block-params" },
  { "include": "#blocks" },

  { "include": "#methods" },
  { "include": "#function-calls" },

  { "include": "#identifiers" }
  ],

  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tira",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.tira",
          "match": "\\A#!.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tira",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.tira" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.tira" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tira",
          "match": "\\b(func|if|else|nil|it|for|do|then)\\b"
        },
        {
          "match": "^(\\s*)(unc|if|else|nil|it|for|do|then)\\b",
          "captures": {
            "2": { "name": "keyword.control.tira" }
          }
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.tira",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.decimal.tira",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "ranges": {
      "patterns": [
        {
          "name": "keyword.operator.range.tira",
          "match": "\\.\\.=|\\.\\."
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.tira",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.tira",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.tira",
          "match": "\\+|\\-|\\*|\\/"
        },
        {
          "name": "keyword.operator.arrow.tira",
          "match": "=>"
        }
      ]
    },

    "methods": {
      "patterns": [
        {
          "name": "entity.name.function.method.tira",
          "match": "\\.[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },

    "block-params": {
      "patterns": [
        {
          "begin": "\\{\\s*(?=[^}]*=>)",
          "beginCaptures": {
            "0": { "name": "punctuation.section.block.begin.tira" }
          },
          "end": "(?==>)",
          "patterns": [
            {
              "match": "[a-zA-Z_][a-zA-Z0-9_]*",
              "name": "variable.parameter.block.tira"
            }
          ]
        }
      ]
    },

    "blocks": {
      "patterns": [
        {
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.block.begin.tira" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.block.end.tira" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },

    "kernel-functions": {
      "patterns": [
        {
          "match": "^(\\s*)(p|puts|print|exit|abort|sleep|rand)\\b",
          "captures": {
            "2": { "name": "support.function.kernel.tira" }
          }
        },
        {
          "match": "\\b(p|puts|print|exit|abort|sleep|rand)\\b(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.function.kernel.tira" }
          }
        }
      ]
    },

    "class-identifiers": {
      "patterns": [
        {
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
          "name": "support.class.tira"
        }
      ]
    },

    "function-declarations": {
      "patterns": [
        {
          "match": "\\bfunc\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.tira"
            }
          }
        }
      ]
    },

    "function-calls": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.tira"
            }
          }
        },
        {
          "match": "^(\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s+(?:[a-zA-Z_][a-zA-Z0-9_]*|\\d+|\"|'))",
          "captures": {
            "2": {
              "name": "entity.name.function.tira"
            }
          }
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "begin": "^(\\s*)(?=[a-zA-Z_][a-zA-Z0-9_]*\\s*(?:,|=))",
          "end": "(?==)",
          "patterns": [
            {
              "match": "[a-zA-Z_][a-zA-Z0-9_]*",
              "name": "variable.other.assignment.tira"
            }
          ]
        }
      ]
    }

  }
}