    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceRoot}/build/tira_debug",
            "args": ["tira_pkgs/repl/repl.tira"],
            "cwd": "${workspaceRoot}",
            "preLaunchTask": "build",
            "terminal": "console",       // use the debug console
            "internalConsoleOptions": "openOnSessionStart"
        }
    ]
}